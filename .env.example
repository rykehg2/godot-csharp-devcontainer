# API Keys para os provedores de IA
# Renomeie este arquivo para .env e preencha as chaves
# NOTA: O devcontainer.json está configurado para ler estas variáveis do seu sistema HOST.

GEMINI_API_KEY=sua_chave_aqui
ANTHROPIC_API_KEY=sua_chave_aqui
OPENAI_API_KEY=sua_chave_aqui

# Configuração do Aider
AIDER_MODEL=gemini/gemini-1.5-pro
AIDER_DARK_MODE=true
