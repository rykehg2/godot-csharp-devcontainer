{
  "name": "Godot C# DevContainer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerEnv": {
    "DOTNET_ROOT": "/usr/lib64/dotnet",
    "DOTNET_SYSTEM_GLOBALIZATION_INVARIANT": "0",
    // Available Model Aliases
    "MODEL_GEMINI_FAST": "gemini-3.1-pro-preview",
    "MODEL_CLAUDE": "claude-3-5-sonnet-20241022",
    "MODEL_GPT4": "gpt-4o",
    "MODEL_QWEN": "ollama/qwen2.5-coder",
    // Key Mapping (OpenCode will read these variables)
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "geequlim.godot-tools",
        "EditorConfig.EditorConfig"
      ],
      "settings": {
        "dotnet.defaultSolution": "game/*.sln",
        // 🔥 force stable mode
        "dotnet.server.useOmnisharp": true,
        // ❗ prevents automatic runtime downloads
        "dotnet.acquireRuntime.enable": false,
        // quality of life
        "editor.formatOnSave": true,
        "files.exclude": {
          "**/.git": false
        },
        "editor.codeActionsOnSave": {
          "source.fixAll": "always",
          "source.organizeImports": "always"
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.autoReveal": true,
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash"
          }
        }
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/run_post_create.sh",
  "remoteUser": "root"
}